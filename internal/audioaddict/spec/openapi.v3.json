  "info": {
    "contact": {
      "name": "Digitally Imported, support@di.fm"
    },
    "description": "A suite of internet radio services and related metadata, membership,\npreference, and advertising functions.\n\nHTTPS is preferred for all requests. HTTP/2 is available on all\nendpoints, and is also preferred if your client supports it.\n\nUse a unique, meaningful `User-Agent` string when sending requests to\nthe API. Version your `User-Agent` header (eg, append a -v1 or similar)\nto allow for varying functionality based on client in the future.\n",
    "termsOfService": "https://www.di.fm/member/tos",
    "title": "AudioAddict Platform API",
    "version": "1"
  },
  "openapi": "3.0.0",
  "paths": {},
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "api_key": {
      "deprecated": true,
      "description": "Member-based auth which provides global access to act as a user on the API. Prefer using a session-based token like the Audio Token or Session Key instead.\n",
      "in": "header",
      "name": "X-Api-Key",
      "type": "apiKey"
    },
    "audio_token": {
      "description": "Session-based auth only valid for operations related to audio playback and performance reporting. Less-sensitive alternative to Session Keys which cannot be used for any member or billing related API calls.\n",
      "in": "header",
      "name": "X-Audio-Token",
      "type": "apiKey"
    },
    "session_key": {
      "description": "Unique bearer token for identifying a specific member session, provides full API access in all auth contexts.\n",
      "in": "header",
      "name": "X-Session-Key",
      "type": "apiKey"
    }
  }
}
