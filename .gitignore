# Build output
bin/
dist/

# Go test/profile artefacts
*.test
*.out
*.prof
coverage.*

# Local devcell container state — regenerated by `cell build` from .devcell.toml
/.devcell/

# Runtime debug log — written by `addiplay --debug` (default: ./debug.log).
# May contain URLs, content-types, and other trace data; never commit.
/debug.log

# Editor / IDE
/.idea/
/.vscode/

# macOS
.DS_Store

# Secrets (allow only the .env.example template)
.env
.env.*
!.env.example
